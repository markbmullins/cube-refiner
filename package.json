{
  "name": "cube-refiner",
  "version": "1.0.0",
  "description": "ETL and analytics tooling for building a 2013-2017 Modern nostalgia cube from historical decklists.",
  "bin": {
    "cube-refiner": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "collect:all": "tsx src/cli/index.ts collect:all",
    "collect:mtggoldfish": "tsx src/cli/index.ts collect:mtggoldfish",
    "collect:mtgo": "tsx src/cli/index.ts collect:mtgo",
    "collect:mtgtop8": "tsx src/cli/index.ts collect:mtgtop8",
    "dedupe:decks": "tsx src/cli/index.ts dedupe:decks",
    "dev": "tsx src/cli/index.ts",
    "matrix:build": "tsx src/cli/index.ts matrix:build",
    "normalize:archetypes": "tsx src/cli/index.ts normalize:archetypes",
    "normalize:cards": "tsx src/cli/index.ts normalize:cards",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "magic-the-gathering",
    "cube",
    "modern",
    "etl",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "type": "module"
}
